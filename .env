# Optional: use OpenAI to generate higher quality posts.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.9

# Optional: if you have your own LinkedIn posting service/API, configure it here.
# The tool will POST { text, scheduled_at, topic } to LINKEDIN_API_URL with Bearer token auth.
LINKEDIN_API_URL=https://your-domain.com/linkedin/post
LINKEDIN_API_TOKEN=your_token_here
LINKEDIN_API_TIMEOUT_S=30

# Where to write copy-paste browser automation fallback files.
AUTOPOST_OUT_DIR=./autopost_out
